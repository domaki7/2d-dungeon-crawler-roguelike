; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Dungeon Descent"
run/main_scene="res://scenes/main/main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

EventBus="*res://scripts/autoload/event_bus.gd"
CombatManager="*res://scripts/autoload/combat_manager.gd"
DungeonManager="*res://scripts/autoload/dungeon_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
RunManager="*res://scripts/autoload/run_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
GameConfig="*res://scripts/autoload/game_config.gd"
VFXHelper="*res://scripts/autoload/vfx_helper.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/mode=3
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="viewport"

